<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         failOnRisky="true"
         failOnWarning="true">
    <testsuites>
        <testsuite name="unit">
            <directory>tests/Unit</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
        <exclude>
            <!-- Live-socket transport glue: requires a server extension/library
                 (ext-swoole, amphp/http-server) and a real connection, so these are
                 exercised by the cross-SDK conformance suite rather than unit tests.
                 Mirrored in codecov.yml (ignore) and infection.json5.dist (excludes). -->
            <file>src/Server/SwooleServer.php</file>
            <file>src/Server/AmpStreamingServer.php</file>
            <file>src/Server/AmpStreamTransport.php</file>
        </exclude>
    </source>
</phpunit>
